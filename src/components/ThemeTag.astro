---
// src/components/ThemeTag.astro
// Kept as a thin wrapper for backward compatibility with existing
// callers (e.g. index.astro uses theme_name={theme}).
// New code should import Tag.astro directly — this and Category.astro
// were previously two copies of the same markup.
import Tag from "./Tag.astro";

interface Props {
    theme_name: string;
    href?: string;
}

const { theme_name, href } = Astro.props;
---

<Tag label={theme_name} href={href} />