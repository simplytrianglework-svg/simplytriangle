---
import BaseLayout from "../layouts/BaseLayout.astro";
import Brand from "../components/Brand.astro";
import PostCard from "../components/PostCard.astro";
import Tag from "../components/Tag.astro";
import { getCollection } from "astro:content";

// 1. Get every post
const allPosts = await getCollection("posts");

// 2. From all posts, keep only the ones marked featured: true
const featuredPosts = allPosts.filter(post => post.data.featured);

// 3. Sort newest first, then take only the first 3.
// FIXED: Array.prototype.sort() mutates the array it's called on.
// The original wrote `allPosts.sort(...)`, which reorders allPosts
// itself — not just the new recentPosts variable. That happened to
// be harmless here only because featuredPosts (a .filter, which does
// NOT mutate) was computed on the line above. Swap these two lines
// in the future and featuredPosts silently inherits date-sorted
// order instead of source order. Spreading into a new array first
// removes that landmine entirely.
const recentPosts = [...allPosts].sort((a, b) => b.data.date - a.data.date).slice(0, 3);

// Previously these were hardcoded strings with no working links —
// clicking a pill did nothing, and even once linked, a hardcoded list
// could point at a category/theme with zero matching posts. Pulling
// from the real post data guarantees every pill here goes somewhere
// with actual results, filtered on the new /bookshelf page.
const categories = [...new Set(allPosts.map(post => post.data.category).filter(Boolean))].sort();
const themes = [...new Set(allPosts.flatMap(post => post.data.tags ?? []))].sort();
---

<BaseLayout title="Home">
	<Brand />

	<section class="featured-posts">
		<h2>Featured Posts</h2>
		<div class="post-grid">
			{featuredPosts.map(post => (
				<PostCard
					title={post.data.title}
					description={post.data.description}
					href={`/posts/${post.id}`}
					image={post.data.image}
					date={post.data.date}
				/>
			))}
		</div>
	</section>


	<section class="category-tags">
		{categories.map(category => (
			<Tag label={category} href={`/bookshelf?category=${encodeURIComponent(category.toLowerCase())}`} />
		))}
	</section>
	<section class="theme-tags">
		{themes.map(theme => (
			<Tag label={theme} href={`/bookshelf?tag=${encodeURIComponent(theme.toLowerCase())}`} />
		))}
	</section>

	<!-- Previously the only route to /newsletter was a small footer
	     text link — nothing on the homepage itself told a first-time
	     visitor a newsletter even existed. Reusing .post-subscribe-cta
	     styling so it feels like one consistent invitation site-wide
	     rather than a one-off homepage banner. -->
	<section class="post-subscribe-cta home-subscribe-cta">
		<h3>Never miss a story</h3>
		<p>New folklore notes, poetry, and Sky Train updates — straight to your inbox.</p>
		<a href="/newsletter" class="post-subscribe-link">Subscribe to the Newsletter</a>
	</section>

	<section class="author-introduction">
		<h2>About the Author</h2>
		<div class="author-card">
			<div class="author-image">
				<img src="#" alt="#"/>		
			</div>

			<div class="author-card-content">
				<h3>Author's name</h3>
				<p>Welcome & Introduction</p>
			</div>
		</div>
		
		<!--Will add an arrow at the end so user will be guided that there is more; flex due to format, grid is also possible.-->
	</section>

	<!-- 4. For each recent post, render one 
	PostCard with that post's data -->

	<section class="recent-posts">
		<h2>Recent Posts</h2>
		<div class="post-grid">
			{recentPosts.map(post => (
				<PostCard
					title={post.data.title}
					description={post.data.description}
					href={`/posts/${post.id}`}
					image={post.data.image}
					date={post.data.date}
				/>
			))}
		</div>
	</section>
	
<!--Header: display flex, controls Brand + Nav children
	container: grid for main layout
	featured-posts: grid for even spacing
	theme-tags: flex so pills wrap on overflow
-->
</BaseLayout>