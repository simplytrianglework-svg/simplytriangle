---
import BaseLayout from "../layouts/BaseLayout.astro";
import Brand from "../components/Brand.astro";
import { getCollection } from "astro:content";

// Small, real numbers instead of more placeholder text — pulled live
// from the same post data driving the Bookshelf, so this stays
// accurate without any manual upkeep as new stories go up.
const allPosts = await getCollection("posts");
const storyCount = allPosts.length;
const categoryCount = new Set(allPosts.map(post => post.data.category).filter(Boolean)).size;
const themeCount = new Set(allPosts.flatMap(post => post.data.tags ?? [])).size;
---

<BaseLayout title="About">
    <Brand />
    <div class="about-card">
        <div class="author-profile-card">
            <div class="author-profile-image">
                <!-- Placeholder monogram in place of a broken image
                     reference. Swap this whole div for a real portrait
                     once you have one:
                     <img src="/images/author.jpg" alt="[Your name], author of Coffee Break" /> -->
                <div class="author-photo-placeholder" aria-hidden="true">
                    <span>CB</span>
                </div>
            </div>

            <div class="profile-card-content">
                <div class="author-introduction">
                    <h2>Hi, I'm simplytriangle</h2>
                    <p>
                        I'm an independent writer that wants to leave a mark on
                        the world. I write short stories, poetry, and occasional
                        deep-dive analysis - most of it circling back to the stories
                        I grew up hearing. Coffee Break is my bookshelf of memories,
                        questions, and imaginations. Let's drink a coffee, one story
                        at a time.
                    </p>
                </div>

                <div class="author-stats">
                    <div class="stat-item">
                        <span class="stat-number">{storyCount}</span>
                        <span class="stat-label">{storyCount === 1 ? "Story" : "Stories"} Published</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-number">{categoryCount}</span>
                        <span class="stat-label">{categoryCount === 1 ? "Category" : "Categories"}</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-number">{themeCount}</span>
                        <span class="stat-label">{themeCount === 1 ? "Theme" : "Themes"} Explored</span>
                    </div>
                </div>

                <div class="author-now-writing">
                    <span class="now-writing-dot" aria-hidden="true"></span>
                    <div>
                        <span class="now-writing-label">Currently writing</span>
                        <p class="now-writing-title">Minokawa conquers the Moon and Sun : A Folklore Retelling</p>
                    </div>
                </div>

                <div class="author-interests">
                    <h3>What I'm Into</h3>
                    <ul class="author-interest-list">
                        <li class="interest-item">Mythologies</li>
                        <li class="interest-item">Folklore &amp; oral tradition</li>
                        <li class="interest-item">Astronomy</li>
                        <li class="interest-item">Poetry</li>
                        <li class="interest-item">Old libraries</li>
                        <li class="interest-item">A sip of dark coffee</li>
                        <li class="interest-item">Dark whimsical stories</li>
                    </ul>
                </div>

                <div class="author-experiences">
                    <h3>A Little Backstory</h3>
                    <p>
                        I've always loved writing, but I truly picked up the pen 
                        again after joining a theatre club as a creative writer. 
                        Around the same time, I began paying closer attention
                        to the stories passed down through my family. 
                        Strange encounters with doppelgangers, shadow people,
                        nature spirits, and other unexplained tales were common topics growing up. 
                        Whether they're folklore, family lore, or something else entirely, 
                        they sparked a curiosity that eventually led me to study Philippine folklore more seriously.
                    </p>
                </div>

                <div class="author-milestones">
                    <h3>Milestones</h3>
                    <ol class="milestone-list">
                        <li class="milestone-item">
                            <span class="milestone-year">2026</span>
                            <span class="milestone-text">Coffee Break is now live!</span>
                        </li>
                    </ol>
                </div>

                <div class="author-links">
                    <h3>Let's Talk</h3>
                    <p>Got a story recommendation, a correction on a retelling, or just want to say hi?</p>
                    <ul class="social-links">
                        <li class="social-link-item">
                            <a href="mailto:simplytriangle.work@gmail.com">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/></svg>
                                Email
                            </a>
                        </li>
                        <li class="social-link-item">
                            <a href="https://www.instagram.com/simplytriangle/" target="_blank" rel="noopener noreferrer">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><path d="M17.5 6.5h.01"/></svg>
                                Instagram
                            </a>
                        </li>
                    </ul>

                    <div class="work-cta">
                        <a href="/work-with-me">Interested in working with me? →</a>
                        <a href="/bookshelf">Browse the Bookshelf →</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

</BaseLayout>