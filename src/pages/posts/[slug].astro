---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Tag from "../../components/Tag.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
    const posts = await getCollection("posts");
    // Sorted newest-first once, up front, so every page's prev/next
    // pair follows the same chronological order readers see on the
    // homepage and recent-posts lists.
    const sorted = [...posts].sort((a, b) => b.data.date - a.data.date);

    return sorted.map((post, index) => ({
        params: { slug: post.id },
        props: {
            post,
            prevPost: sorted[index + 1] ?? null, // older post
            nextPost: sorted[index - 1] ?? null, // newer post
        },
    }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);
const hasAudio = !!post.data.audio;
---

<BaseLayout title={post.data.title}>

    <div class="progress-bar" id="progress-bar" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-label="Reading progress"></div>

    <article class="post-content-card">

        {hasAudio && (
            <button class="audio-toggle" id="audio-toggle" title="Listen to this post" aria-expanded="false" aria-controls="audio-panel">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
                    <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
                    <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
                </svg>
            </button>
        )}

        {hasAudio && (
            <div class="audio-panel" id="audio-panel">
                <audio controls src={post.data.audio} class="audio-element">
                    Your browser does not support audio.
                </audio>
            </div>
        )}

        <div class="post-header">
            <h2>{post.data.title}</h2>
            <p class="post-description">{post.data.description}</p>
        </div>

        <div class="post-cover-wrapper">
            <img src={post.data.image} alt={post.data.title} class="post-cover"/>
        </div>
        
        <div class="post-body">
            <Content />
        </div>

        {(post.data.category || (post.data.tags && post.data.tags.length > 0)) && (
            <div class="post-tags">
                {post.data.category && (
                    <Tag label={post.data.category} href={`/bookshelf?category=${encodeURIComponent(post.data.category.toLowerCase())}`} />
                )}
                {post.data.tags?.map(tag => (
                    <Tag label={tag} href={`/bookshelf?tag=${encodeURIComponent(tag.toLowerCase())}`} />
                ))}
            </div>
        )}

    </article>

    <!-- Reader just finished the piece — this is the single highest-
         intent moment on the whole site to ask them to subscribe.
         Previously the only path to /newsletter was a small text
         link in the footer nav, easy to miss entirely. -->
    <section class="post-subscribe-cta">
        <h3>Enjoyed this one?</h3>
        <p>Get new stories, poems, and folklore notes from Coffee Break straight to your inbox.</p>
        <a href="/newsletter" class="post-subscribe-link">Subscribe to the Newsletter</a>
    </section>

    {(prevPost || nextPost) && (
        <nav class="post-nav" aria-label="Post navigation">
            {prevPost ? (
                <a href={`/posts/${prevPost.id}`} class="post-nav-link post-nav-prev">
                    <span class="post-nav-label">← Older</span>
                    <span class="post-nav-title">{prevPost.data.title}</span>
                </a>
            ) : <span class="post-nav-link post-nav-empty" />}

            {nextPost ? (
                <a href={`/posts/${nextPost.id}`} class="post-nav-link post-nav-next">
                    <span class="post-nav-label">Newer →</span>
                    <span class="post-nav-title">{nextPost.data.title}</span>
                </a>
            ) : <span class="post-nav-link post-nav-empty" />}
        </nav>
    )}
</BaseLayout>

<script>
    const bar = document.getElementById("progress-bar");

    // FIXED: docHeight is (scrollHeight - innerHeight), which is 0
    // whenever the post's content is shorter than the viewport — a
    // very real case for short poems. Dividing by 0 produces NaN,
    // and setting style.width to "NaN%" is silently ignored by the
    // browser rather than throwing, so the bug was invisible unless
    // you specifically tested with a short post.
    function updateProgress() {
        if (!bar) return;
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        bar.style.width = `${progress}%`;
        bar.setAttribute("aria-valuenow", String(Math.round(progress)));
    }

    window.addEventListener("scroll", updateProgress);
    // Run once on load too, otherwise the bar sits at its default
    // width until the user's first scroll event fires.
    updateProgress();

    const toggleBtn = document.getElementById("audio-toggle");
    const audioPanel = document.getElementById("audio-panel");

    if (toggleBtn && audioPanel) {
        toggleBtn.addEventListener("click", () => {
            const isOpen = audioPanel.classList.toggle("open");
            toggleBtn.classList.toggle("active");
            toggleBtn.setAttribute("aria-expanded", String(isOpen));
        });
    }
</script>