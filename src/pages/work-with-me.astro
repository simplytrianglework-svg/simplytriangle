---
import BaseLayout from "../layouts/BaseLayout.astro";
import Brand from "../components/Brand.astro";
---
<BaseLayout title="Work with Me">
    <Brand />

    <div class="work-card">
        <div class="work-content-container">
            <div class="main-work-content">
                <h2>Work with Me</h2>

                <div class="work-image">
                    <div class="work-image-placeholder" aria-hidden="true">
                        <span>Placeholder — photo or portrait of simplytriangle</span>
                    </div>
                </div>

                <h3>Brief Introduction</h3>
                <p>
                    I'm SimplyTriangle, an independent writer researching and 
                    reimagining Philippine folklore through stories, 
                    poetry, and literary analysis.
                    <a href="/about">Read more about me</a>.
                </p>

                <h3>What I Can Do</h3>
                <ul class="work-scenario-list">
                    <li>Need original short fiction or poetry for your publication, zine, or anthology?</li>
                    <li>Need well-researched folklore or mythology articles, analyses, or retellings adapted for modern readers?</li>
                    <li>Want your brand to communicate with a distinctive literary voice?</li>
                    <li>Looking for original illustrations or graphic design for a book, article, or creative project?</li>
                </ul>

                <h3>When Will You Need My Help?</h3>
                <ul class="work-scenario-list">
                    <li>You're building an anthology or zine and need a folklore-rooted piece</li>
                    <li>You have a draft that needs an outside editorial eye before submission</li>
                    <li>You want copy that reads like a story, not a sales page</li>
                </ul>

                <div class="work-inquiry-cta">
                    <h3>Let's Work Together</h3>
                    <p>Tell me a bit about your project and timeline — I'll get back to you within a few days.</p>
                    <a href="mailto:simplytriangle.work@gmail.com" class="work-inquiry-link">Send an inquiry →</a>
                </div>
            </div>

            <div class="secondary-work-content">
                <div class="author-skills">
                    <h3>Author's Skills</h3>
                    <ul class="author-skill-list">
                        <li class="skill-item">Folklore &amp; mythology research</li>
                        <li class="skill-item">Short fiction &amp; poetry</li>
                        <li class="skill-item">Graphic Designing</li>
                        <li class="skill-item">Digital Drawing</li>
                        <li class="skill-item">Line editing &amp; proofreading</li>
                    </ul>
                </div>

                <div class="work-availability">
                    <span class="availability-dot" aria-hidden="true"></span>
                    <span>Currently open for new projects</span>
                </div>
                <div class="work-availability">
                    <span class="availability-dot" aria-hidden="true"></span>
                    <span>Usually responds within 3-5 business days.</span>
                </div>

            </div>
        </div>
    </div>

</BaseLayout>