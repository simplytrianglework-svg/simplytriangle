---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("posts");
const sorted = [...allPosts].sort((a, b) => b.data.date - a.data.date);

// Pulled from real post data (not a hardcoded list) so a pill can
// never link to a category/theme that has zero matching entries.
const categories = [...new Set(sorted.map(post => post.data.category).filter(Boolean))].sort();
const themes = [...new Set(sorted.flatMap(post => post.data.tags ?? []))].sort();
---

<BaseLayout title="The Bookshelf">

    <section class="bookshelf-hero">
        <h2>The Bookshelf</h2>
        <p>Stories, poems, and analyses, all in one place. Search by title, or narrow things down by category and theme.</p>

        <div class="bookshelf-search">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="bookshelf-search-icon">
                <circle cx="11" cy="11" r="8"/>
                <path d="m21 21-4.3-4.3"/>
            </svg>
            <input
                type="search"
                id="bookshelf-search-input"
                class="bookshelf-search-input"
                placeholder="Search by title or description…"
                aria-label="Search the bookshelf"
            />
        </div>

        {categories.length > 0 && (
            <div class="bookshelf-filter-group" role="group" aria-label="Filter by category">
                <span class="bookshelf-filter-label">Category</span>
                <div class="bookshelf-filter-pills" id="category-pills">
                    <button type="button" class="theme-pill filter-pill is-active" data-filter="category" data-value="all">All</button>
                    {categories.map(category => (
                        <button type="button" class="theme-pill filter-pill" data-filter="category" data-value={category.toLowerCase()}>{category}</button>
                    ))}
                </div>
            </div>
        )}

        {themes.length > 0 && (
            <div class="bookshelf-filter-group" role="group" aria-label="Filter by theme">
                <span class="bookshelf-filter-label">Theme</span>
                <div class="bookshelf-filter-pills" id="theme-pills">
                    <button type="button" class="theme-pill filter-pill is-active" data-filter="tag" data-value="all">All</button>
                    {themes.map(theme => (
                        <button type="button" class="theme-pill filter-pill" data-filter="tag" data-value={theme.toLowerCase()}>{theme}</button>
                    ))}
                </div>
            </div>
        )}
    </section>

    <section class="bookshelf-results">
        <p class="bookshelf-count" id="bookshelf-count" aria-live="polite"></p>

        <div class="post-grid bookshelf-grid" id="bookshelf-grid">
            {sorted.map(post => (
                <div
                    class="bookshelf-card"
                    data-title={post.data.title.toLowerCase()}
                    data-description={post.data.description.toLowerCase()}
                    data-category={(post.data.category ?? "").toLowerCase()}
                    data-tags={(post.data.tags ?? []).join("|").toLowerCase()}
                >
                    <PostCard
                        title={post.data.title}
                        description={post.data.description}
                        href={`/posts/${post.id}`}
                        image={post.data.image}
                        date={post.data.date}
                    />
                </div>
            ))}
        </div>

        <div class="bookshelf-empty" id="bookshelf-empty" hidden>
            <p>Nothing matches that search just yet. Try a different word, or clear the filters below.</p>
            <button type="button" class="error-link" id="bookshelf-clear">Clear filters</button>
        </div>
    </section>

</BaseLayout>

<script>
    // Astro's static build has no server-side knowledge of query
    // params, so filtering (both the initial ?category=/?tag= state
    // from links elsewhere on the site, and live search) all happens
    // here on the client against the data-* attributes rendered above.
    const searchInput = document.getElementById("bookshelf-search-input") as HTMLInputElement | null;
    const grid = document.getElementById("bookshelf-grid");
    const cards = Array.from(document.querySelectorAll<HTMLElement>(".bookshelf-card"));
    const countEl = document.getElementById("bookshelf-count");
    const emptyEl = document.getElementById("bookshelf-empty");
    const clearBtn = document.getElementById("bookshelf-clear");
    const categoryPills = document.querySelectorAll<HTMLButtonElement>('#category-pills .filter-pill');
    const themePills = document.querySelectorAll<HTMLButtonElement>('#theme-pills .filter-pill');

    let activeCategory = "all";
    let activeTag = "all";

    function setActivePill(pills: NodeListOf<HTMLButtonElement>, value: string) {
        pills.forEach(pill => {
            pill.classList.toggle("is-active", pill.dataset.value === value);
        });
    }

    function applyFilters() {
        const query = (searchInput?.value ?? "").trim().toLowerCase();
        let visibleCount = 0;

        cards.forEach(card => {
            const matchesQuery =
                query === "" ||
                (card.dataset.title ?? "").includes(query) ||
                (card.dataset.description ?? "").includes(query);

            const matchesCategory =
                activeCategory === "all" || card.dataset.category === activeCategory;

            const cardTags = (card.dataset.tags ?? "").split("|");
            const matchesTag = activeTag === "all" || cardTags.includes(activeTag);

            const isVisible = matchesQuery && matchesCategory && matchesTag;
            card.hidden = !isVisible;
            if (isVisible) visibleCount++;
        });

        if (countEl) {
            countEl.textContent =
                visibleCount === 0
                    ? ""
                    : `Showing ${visibleCount} ${visibleCount === 1 ? "entry" : "entries"}`;
        }

        if (grid) grid.hidden = visibleCount === 0;
        if (emptyEl) emptyEl.hidden = visibleCount !== 0;
    }

    function syncUrl() {
        const params = new URLSearchParams(window.location.search);

        activeCategory === "all" ? params.delete("category") : params.set("category", activeCategory);
        activeTag === "all" ? params.delete("tag") : params.set("tag", activeTag);

        const query = params.toString();
        const newUrl = `${window.location.pathname}${query ? `?${query}` : ""}`;
        window.history.replaceState({}, "", newUrl);
    }

    categoryPills.forEach(pill => {
        pill.addEventListener("click", () => {
            activeCategory = pill.dataset.value ?? "all";
            setActivePill(categoryPills, activeCategory);
            syncUrl();
            applyFilters();
        });
    });

    themePills.forEach(pill => {
        pill.addEventListener("click", () => {
            activeTag = pill.dataset.value ?? "all";
            setActivePill(themePills, activeTag);
            syncUrl();
            applyFilters();
        });
    });

    searchInput?.addEventListener("input", applyFilters);

    clearBtn?.addEventListener("click", () => {
        if (searchInput) searchInput.value = "";
        activeCategory = "all";
        activeTag = "all";
        setActivePill(categoryPills, "all");
        setActivePill(themePills, "all");
        syncUrl();
        applyFilters();
    });

    // Read initial state from the URL (e.g. a Tag link from the
    // homepage pointing to /bookshelf?tag=nostalgia) so a filtered
    // link actually lands the reader on a filtered view instead of
    // the full list.
    const initialParams = new URLSearchParams(window.location.search);
    const initialCategory = initialParams.get("category");
    const initialTag = initialParams.get("tag");

    if (initialCategory) {
        activeCategory = initialCategory.toLowerCase();
        setActivePill(categoryPills, activeCategory);
    }
    if (initialTag) {
        activeTag = initialTag.toLowerCase();
        setActivePill(themePills, activeTag);
    }

    applyFilters();
</script>
