---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 - Page Not Found">
    <div class="error-container">
        <h2>404</h2>
        <p>Looks like this page took a coffee break and never came back.</p>
        <div class="error-actions">
            <a href="/" class="error-link">Back to Home</a>
            <a href="/bookshelf" class="error-link error-link-secondary">Browse the Bookshelf</a>
        </div>
    </div>
</BaseLayout>