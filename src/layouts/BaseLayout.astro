---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import { getCollection } from "astro:content";

const { title, fullWidth = false, description, image, date } = Astro.props;

const allPosts = await getCollection("posts");

// Sorted so the sidebar order is stable and predictable rather than
// depending on filesystem read order, which can vary across machines
// and isn't guaranteed by the glob loader.
// Both lists are pulled straight from post frontmatter, so dropping a
// new .md file with a new category or tag in it is all it takes for
// the sidebar to pick it up on the next build — nothing to hand-edit.
const categories = [...new Set(allPosts.map(post => post.data.category).filter(Boolean))].sort();
const themes = [...new Set(allPosts.flatMap(post => post.data.tags ?? []))].sort();
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>{title} | Coffee Break</title>

    <!-- SEO -->
    <meta name="description" content={description ?? "A literary archive of Filipino folklore, mythology, poetry, and short stories."} />
    <link rel="canonical" href={Astro.url.href} />

    <!-- Open Graph (Facebook + Pinterest previews) -->
    <meta property="og:type" content="article" />
    <meta property="og:title" content={`${title} | Coffee Break`} />
    <meta property="og:description" content={description ?? "A literary archive of Filipino folklore, mythology, poetry, and short stories."} />
    <meta property="og:url" content={Astro.url.href} />
    {image && <meta property="og:image" content={new URL(image, Astro.site).href} />}
    {date && <meta property="article:published_time" content={new Date(date).toISOString()} />}

    <!-- Twitter/X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Coffee Break`} />
    <meta name="twitter:description" content={description ?? "A literary archive of Filipino folklore, mythology, poetry, and short stories."} />
    {image && <meta name="twitter:image" content={new URL(image, Astro.site).href} />}


    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <!-- Redesign: Fraunces replaces Playfair Display for headings.
         Playfair's sharp, high-contrast strokes read as "luxury
         menu/fashion editorial" — striking, but not what a late-
         night story site wants. Fraunces is a warmer, more organic
         literary serif (its italic in particular feels handwritten
         and unhurried), which better matches "reading a story by
         lamplight." Inter is added as a small quiet sans, used only
         for nav labels/eyebrows/buttons, so functional UI chrome
         stays out of the way of the serif reading voice. Lora and
         Cormorant Garamond are kept for body text and italic accents. -->
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500;1,9..144,600&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Lora:ital,wght@0,400;0,500;1,400&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
</head>
<body>

    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar" aria-label="Browse the bookshelf">
        <div class="sidebar-header">
            <span class="sidebar-title">Coffee Break</span>
            <button class="sidebar-close" id="sidebar-close" aria-label="Close sidebar">✕</button>
        </div>
        <nav class="sidebar-nav">
            {categories.length > 0 && (
                <div class="sidebar-section">
                    <span class="sidebar-section-label">Category</span>
                    {categories.map(category => (
                        <a
                            class="sidebar-link"
                            href={`/bookshelf?category=${encodeURIComponent(category.toLowerCase())}`}
                            data-filter-type="category"
                            data-filter-value={category.toLowerCase()}
                        >
                            {category}
                        </a>
                    ))}
                </div>
            )}

            {themes.length > 0 && (
                <div class="sidebar-section">
                    <span class="sidebar-section-label">Themes</span>
                    {themes.map(theme => (
                        <a
                            class="sidebar-link"
                            href={`/bookshelf?tag=${encodeURIComponent(theme.toLowerCase())}`}
                            data-filter-type="tag"
                            data-filter-value={theme.toLowerCase()}
                        >
                            {theme}
                        </a>
                    ))}
                </div>
            )}

            <a class="sidebar-link sidebar-link-all" href="/bookshelf">View the Bookshelf →</a>
        </nav>
    </aside>

    <!-- Overlay -->
    <div class="sidebar-overlay" id="sidebar-overlay"></div>

    <!-- Page wrapper -->
    <div class="page-wrapper">
        <header class="main-header">
            <button class="hamburger" id="hamburger" aria-label="Open sidebar" aria-controls="sidebar" aria-expanded="false">☰</button>
            <Navbar />
        </header>

        <main class={fullWidth ? "container-full" : "container"}>
            <slot />
        </main>

        <Footer />
    </div>

    <script>
        // Guard every lookup. Previously a single missing element
        // (e.g. after a future markup refactor) would throw on
        // addEventListener and silently kill every script on the
        // page below it, including the unrelated progress bar /
        // audio toggle script on post pages.
        const hamburger = document.getElementById("hamburger");
        const sidebar = document.getElementById("sidebar");
        const overlay = document.getElementById("sidebar-overlay");
        const closeBtn = document.getElementById("sidebar-close");

        function openSidebar() {
            sidebar?.classList.add("open");
            overlay?.classList.add("open");
            hamburger?.setAttribute("aria-expanded", "true");
        }

        function closeSidebar() {
            sidebar?.classList.remove("open");
            overlay?.classList.remove("open");
            hamburger?.setAttribute("aria-expanded", "false");
        }

        hamburger?.addEventListener("click", openSidebar);
        closeBtn?.addEventListener("click", closeSidebar);
        overlay?.addEventListener("click", closeSidebar);

        // Close on Escape, a common accessibility expectation for
        // any off-canvas panel that acts like a modal.
        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && sidebar?.classList.contains("open")) {
                closeSidebar();
            }
        });

        // Highlight whichever sidebar link matches the current
        // /bookshelf?category=/tag= filter, so a reader who arrived via
        // the sidebar (or a pill, or a post-page tag) can see where
        // they are, the same way the active nav link works above.
        const sidebarLinks = document.querySelectorAll<HTMLAnchorElement>(".sidebar-link[data-filter-type]");
        const sidebarAllLink = document.querySelector<HTMLAnchorElement>(".sidebar-link-all");
        if (window.location.pathname === "/bookshelf") {
            const params = new URLSearchParams(window.location.search);
            let anyMatch = false;
            sidebarLinks.forEach(link => {
                const type = link.dataset.filterType;
                const value = link.dataset.filterValue;
                const isMatch = type && value && params.get(type) === value;
                if (isMatch) anyMatch = true;
                link.classList.toggle("active", Boolean(isMatch));
            });
            sidebarAllLink?.classList.toggle("active", !anyMatch);
        }
    </script>

</body>
</html>